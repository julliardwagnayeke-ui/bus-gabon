# ─── Supabase (Project Settings → API) ───
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # secret serveur uniquement — ne jamais exposer côté client

# ─── Base de données Prisma (Project Settings → Database → Connection string) ───
# url = pooler (port 6543, pgbouncer) pour le runtime ; directUrl = connexion directe (port 5432) pour les migrations
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xxx.pooler.supabase.com:5432/postgres"

# ─── Paiement Mobile Money — SingPay (Gabon) ───
SINGPAY_CLIENT_ID=
SINGPAY_CLIENT_SECRET=
SINGPAY_WALLET_ID=
SINGPAY_WEBHOOK_SECRET=

# ─── Email transactionnel (Resend) ───
RESEND_API_KEY=

# ─── WhatsApp Business Cloud API (Meta) ───
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ─── Divers ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
