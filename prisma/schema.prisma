// BusGabon — schéma de données (Postgres / Supabase)
// Doc : https://pris.ly/d/prisma-schema
//
// NB Auth : la table `Profile` (profiles) a un id égal à auth.users.id de Supabase.
// Le lien est maintenu par un trigger SQL côté Supabase (voir supabase/migrations).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // connexion via pooler (runtime)
  directUrl = env("DIRECT_URL") // connexion directe (migrations)
}

// ─────────────────────────────── ENUMS ───────────────────────────────

enum Role {
  client
  super_admin
  finance_admin
  support_admin
  operations_admin
  content_admin
}

enum AgencyRole {
  owner
  manager
  checker
  finance
}

enum AgencyStatus {
  pending_review
  active
  suspended
  rejected
  archived
}

enum BusType {
  classique
  vip
  minibus
  climatise
  grand_bus
}

enum BusStatus {
  active
  inactive
  maintenance
  archived
}

enum RouteStatus {
  active
  inactive
}

enum DepartureStatus {
  draft
  published
  closed
  boarding
  departed
  completed
  cancelled
}

enum PaymentStatus {
  pending
  processing
  paid
  failed
  expired
  refunded
}

enum ReservationStatus {
  pending_payment
  confirmed
  cancelled
  checked_in
  completed
}

enum TicketStatus {
  active
  used
  cancelled
  expired
  invalid
}

enum PaymentMethod {
  airtel
  moov
  card
}

enum PayoutStatus {
  pending
  approved
  processing
  paid
  failed
  disputed
  cancelled
}

enum SupportType {
  payment_issue
  ticket_not_received
  departure_cancelled
  delay
  ticket_refused
  reservation_error
  agency_request
  payout
  technical_issue
  other
}

enum SupportStatus {
  open
  in_progress
  waiting_customer
  waiting_agency
  resolved
  closed
}

enum Priority {
  low
  medium
  high
  urgent
}

enum AlertSeverity {
  low
  medium
  high
  critical
}

// ──────────────────────────── CORE / USERS ───────────────────────────

model Profile {
  id        String   @id @db.Uuid // = auth.users.id
  email     String   @unique
  fullName  String?  @map("full_name")
  phone     String?
  role      Role     @default(client)
  agencyId  String?  @map("agency_id") @db.Uuid
  agency    Agency?  @relation(fields: [agencyId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  reservations Reservation[]
  agencyLinks  AgencyUser[]
  activityLogs ActivityLog[]

  @@index([agencyId])
  @@map("profiles")
}

model Agency {
  id                 String       @id @default(uuid()) @db.Uuid
  name               String
  slug               String?      @unique
  logoUrl            String?      @map("logo_url")
  phone              String?
  whatsapp           String?
  email              String?
  address            String?
  mainCity           String?      @map("main_city")
  mainStation        String?      @map("main_station")
  description        String?
  operatingHours     String?      @map("operating_hours")
  baggagePolicy      String?      @map("baggage_policy")
  cancellationPolicy String?      @map("cancellation_policy")
  status             AgencyStatus @default(pending_review)
  verifiedBadge      Boolean      @default(false) @map("verified_badge")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  members        Profile[]
  agencyUsers    AgencyUser[]
  buses          Bus[]
  routes         Route[]
  departures     Departure[]
  reservations   Reservation[]
  tickets        Ticket[]
  commissions    Commission[]
  payouts        Payout[]
  payoutSettings PayoutSettings?
  supportTickets SupportTicket[]

  @@map("agencies")
}

model AgencyUser {
  id        String     @id @default(uuid()) @db.Uuid
  agencyId  String     @map("agency_id") @db.Uuid
  agency    Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  userId    String     @map("user_id") @db.Uuid
  user      Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      AgencyRole @default(checker)
  status    String     @default("active")
  lastLogin DateTime?  @map("last_login")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@unique([agencyId, userId])
  @@index([userId])
  @@map("agency_users")
}

// ─────────────────────────── FLOTTE / OFFRE ──────────────────────────

model Bus {
  id           String    @id @default(uuid()) @db.Uuid
  agencyId     String    @map("agency_id") @db.Uuid
  agency       Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name         String
  code         String?
  licensePlate String?   @map("license_plate")
  capacity     Int
  type         BusType   @default(classique)
  description  String?
  equipment    String[]  @default([])
  photoUrl     String?   @map("photo_url")
  status       BusStatus @default(active)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  departures Departure[]

  @@index([agencyId])
  @@map("buses")
}

model Route {
  id                String      @id @default(uuid()) @db.Uuid
  agencyId          String      @map("agency_id") @db.Uuid
  agency            Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  fromCity          String      @map("from_city")
  toCity            String      @map("to_city")
  fromStation       String?     @map("from_station")
  toStation         String?     @map("to_station")
  basePrice         Float       @map("base_price")
  estimatedDuration String?     @map("estimated_duration")
  baggageIncluded   Int         @default(1) @map("baggage_included")
  maxBaggageWeight  Int?        @map("max_baggage_weight")
  extraBaggageFee   Float?      @map("extra_baggage_fee")
  description       String?
  status            RouteStatus @default(active)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  departures Departure[]

  @@index([agencyId])
  @@index([fromCity, toCity])
  @@map("routes")
}

model Departure {
  id                       String          @id @default(uuid()) @db.Uuid
  agencyId                 String          @map("agency_id") @db.Uuid
  agency                   Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  routeId                  String          @map("route_id") @db.Uuid
  route                    Route           @relation(fields: [routeId], references: [id])
  busId                    String          @map("bus_id") @db.Uuid
  bus                      Bus             @relation(fields: [busId], references: [id])
  departureDate            DateTime        @map("departure_date") @db.Date
  departureTime            String          @map("departure_time") // HH:mm
  estimatedArrivalTime     String?         @map("estimated_arrival_time")
  ticketPrice              Float           @map("ticket_price")
  openSeats                Int             @map("open_seats")
  soldSeats                Int             @default(0) @map("sold_seats")
  baggageIncluded          Int             @default(1) @map("baggage_included")
  maxBookingPerReservation Int             @default(4) @map("max_booking_per_reservation")
  fromStation              String?         @map("from_station")
  toStation                String?         @map("to_station")
  specialConditions        String?         @map("special_conditions")
  status                   DepartureStatus @default(draft)
  cancellationReason       String?         @map("cancellation_reason")
  delayMinutes             Int?            @map("delay_minutes")
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")

  reservations Reservation[]
  tickets      Ticket[]

  @@index([agencyId])
  @@index([routeId])
  @@index([departureDate, status])
  @@map("departures")
}

// ───────────────────── RÉSERVATION / BILLET / PAIEMENT ───────────────

model Reservation {
  id            String            @id @default(uuid()) @db.Uuid
  code          String            @unique
  departureId   String            @map("departure_id") @db.Uuid
  departure     Departure         @relation(fields: [departureId], references: [id])
  agencyId      String            @map("agency_id") @db.Uuid
  agency        Agency            @relation(fields: [agencyId], references: [id])
  userId        String?           @map("user_id") @db.Uuid
  user          Profile?          @relation(fields: [userId], references: [id])
  clientName    String            @map("client_name")
  clientPhone   String            @map("client_phone")
  clientEmail   String?           @map("client_email")
  totalAmount   Float             @map("total_amount")
  totalPaid     Float             @default(0) @map("total_paid")
  paymentStatus PaymentStatus     @default(pending) @map("payment_status")
  status        ReservationStatus @default(pending_payment)
  expiresAt     DateTime?         @map("expires_at")
  paidAt        DateTime?         @map("paid_at")
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  passengers Passenger[]
  tickets    Ticket[]
  payment    Payment?

  @@index([departureId])
  @@index([agencyId])
  @@index([userId])
  @@index([status])
  @@map("reservations")
}

model Passenger {
  id            String      @id @default(uuid()) @db.Uuid
  reservationId String      @map("reservation_id") @db.Uuid
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  name          String
  phone         String?
  document      String?
  seatNumber    String?     @map("seat_number")
  baggageCount  Int         @default(0) @map("baggage_count")

  @@index([reservationId])
  @@map("passengers")
}

model Ticket {
  id             String       @id @default(uuid()) @db.Uuid
  code           String       @unique
  reservationId  String       @map("reservation_id") @db.Uuid
  reservation    Reservation  @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  departureId    String       @map("departure_id") @db.Uuid
  departure      Departure    @relation(fields: [departureId], references: [id])
  agencyId       String       @map("agency_id") @db.Uuid
  agency         Agency       @relation(fields: [agencyId], references: [id])
  passengerName  String       @map("passenger_name")
  passengerPhone String?      @map("passenger_phone")
  qrPayload      String       @map("qr_payload")
  status         TicketStatus @default(active)
  validatedAt    DateTime?    @map("validated_at")
  validatedBy    String?      @map("validated_by") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([reservationId])
  @@index([departureId])
  @@index([agencyId])
  @@map("tickets")
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  reservationId String        @unique @map("reservation_id") @db.Uuid
  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  amount        Float
  method        PaymentMethod
  provider      String        @default("singpay")
  providerRef   String?       @map("provider_ref")
  status        PaymentStatus @default(pending)
  rawPayload    Json?         @map("raw_payload")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("payments")
}

// ─────────────────────── FINANCE PLATEFORME / AGENCE ─────────────────

model Commission {
  id               String   @id @default(uuid()) @db.Uuid
  agencyId         String   @map("agency_id") @db.Uuid
  agency           Agency   @relation(fields: [agencyId], references: [id])
  period           String // YYYY-MM
  totalSales       Float    @map("total_sales")
  commissionAmount Float    @map("commission_amount")
  userFeesAmount   Float    @map("user_fees_amount")
  totalRevenue     Float    @map("total_revenue")
  netPayout        Float    @map("net_payout")
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([agencyId, period])
  @@index([period])
  @@map("commissions")
}

model Payout {
  id               String       @id @default(uuid()) @db.Uuid
  agencyId         String       @map("agency_id") @db.Uuid
  agency           Agency       @relation(fields: [agencyId], references: [id])
  period           String
  grossSales       Float        @map("gross_sales")
  commission       Float
  netAmount        Float        @map("net_amount")
  status           PayoutStatus @default(pending)
  paymentMethod    String?      @map("payment_method")
  paymentReference String?      @map("payment_reference")
  paymentProof     String?      @map("payment_proof")
  approvedBy       String?      @map("approved_by") @db.Uuid
  approvedAt       DateTime?    @map("approved_at")
  paidAt           DateTime?    @map("paid_at")
  failureReason    String?      @map("failure_reason")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([agencyId])
  @@index([status])
  @@map("payouts")
}

model PayoutSettings {
  id                   String   @id @default(uuid()) @db.Uuid
  agencyId             String   @unique @map("agency_id") @db.Uuid
  agency               Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  method               String // mobile_money, bank_transfer, check
  holderName           String   @map("holder_name")
  mobileNumber         String?  @map("mobile_number")
  bankName             String?  @map("bank_name")
  accountNumber        String?  @map("account_number")
  iban                 String?
  financialResponsible String   @map("financial_responsible")
  responsiblePhone     String   @map("responsible_phone")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("payout_settings")
}

// ──────────────────────────── SUPPORT ────────────────────────────────

model SupportTicket {
  id             String        @id @default(uuid()) @db.Uuid
  number         String        @unique
  type           SupportType
  clientOrAgency String        @map("client_or_agency") // client | agency
  clientId       String?       @map("client_id") @db.Uuid
  agencyId       String?       @map("agency_id") @db.Uuid
  agency         Agency?       @relation(fields: [agencyId], references: [id])
  subject        String
  description    String
  priority       Priority      @default(medium)
  status         SupportStatus @default(open)
  assignedToId   String?       @map("assigned_to_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  resolvedAt     DateTime?     @map("resolved_at")

  messages SupportMessage[]

  @@index([status])
  @@index([priority])
  @@map("support_tickets")
}

model SupportMessage {
  id        String        @id @default(uuid()) @db.Uuid
  ticketId  String        @map("ticket_id") @db.Uuid
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String        @map("sender_id") @db.Uuid
  message   String
  fileUrl   String?       @map("file_url")
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([ticketId])
  @@map("support_messages")
}

// ──────────────────────── ADMIN / AUDIT / CONFIG ─────────────────────

model ActivityLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String   @map("actor_id") @db.Uuid
  actor      Profile  @relation(fields: [actorId], references: [id])
  action     String // create, update, delete, approve, suspend...
  module     String // users, agencies, buses, routes, departures...
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([module])
  @@map("activity_logs")
}

model AdminAlert {
  id         String        @id @default(uuid()) @db.Uuid
  type       String
  title      String
  message    String
  severity   AlertSeverity @default(medium)
  resolved   Boolean       @default(false)
  createdAt  DateTime      @default(now()) @map("created_at")
  resolvedAt DateTime?     @map("resolved_at")

  @@index([resolved])
  @@map("admin_alerts")
}

model PlatformSettings {
  id                       String   @id @default("singleton")
  commissionPercentage     Float    @default(5) @map("commission_percentage")
  userFeePerTicket         Float    @default(200) @map("user_fee_per_ticket")
  currency                 String   @default("XAF")
  reservationBlockTime     Int      @default(10) @map("reservation_block_time")
  maxTicketsPerBooking     Int      @default(4) @map("max_tickets_per_booking")
  allowGuestReservation    Boolean  @default(true) @map("allow_guest_reservation")
  whatsappEnabled          Boolean  @default(true) @map("whatsapp_enabled")
  emailEnabled             Boolean  @default(true) @map("email_enabled")
  departureReminderEnabled Boolean  @default(true) @map("departure_reminder_enabled")
  departureReminderTime    Int      @default(2) @map("departure_reminder_time") // heures
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

model City {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  slug      String   @unique
  province  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("cities")
}
